# Cloudflare Pages headers config
# Docs: https://developers.cloudflare.com/pages/configuration/headers/

# All routes: security baseline
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# HTML: short cache, must revalidate (so copy edits ship fast)
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Future static assets: long cache (immutable content-hashed)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon + OG image: medium cache
/favicon.ico
  Cache-Control: public, max-age=86400
/og-image.png
  Cache-Control: public, max-age=86400
